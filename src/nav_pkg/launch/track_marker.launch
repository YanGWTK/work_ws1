<launch>
    <include file="$(find easy_handeye)/launch/publish.launch">
        <arg name="namespace_prefix" value="yahboom_handeye"/>
        <arg name="eye_on_hand" value="false"/>
    </include>
    <arg name="markerSize"      default="0.05"/>    
    
    <arg name="markerId"        default="1"/>       
    
    <arg name="camera_frame"    default="camera_color_optical_frame"/> 
    
    <arg name="marker_frame"    default="aruco_marker_frame"/>

    <node pkg="aruco_ros" type="single" name="aruco_single" output="screen">
        
        <remap from="camera_info" to="/camera/rgb/camera_info" />
        <remap from="image"       to="/camera/rgb/image_raw" />
        
        <param name="image_is_rectified" value="True"/>
        <param name="marker_size"        value="$(arg markerSize)"/>
        <param name="marker_id"          value="$(arg markerId)"/>
        <param name="reference_frame"    value="$(arg camera_frame)"/>   
        <param name="camera_frame"       value="$(arg camera_frame)"/>
        <param name="marker_frame"       value="$(arg marker_frame)" />
        
        <param name="publish_tf"         value="true" />
    </node>
</launch>