
<launch>
    <!-- Arm Control System Launch File -->
    
    <!-- 机械臂动作服务器 -->
    <node name="arm_action_server" pkg="armaction" type="arm_server.py" output="screen">
        <param name="debug" value="true" />
    </node>
    <arg name="test" default="false" />
    <arg name="rviz" default="false" />
</launch>
